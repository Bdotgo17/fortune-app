# Shopify storefront token and store domain
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=shpat_xxx

# Price per fortune in cents
FORTUNE_PRICE_CENTS=100

# Server port
PORT=4000

# Optional: a specific ProductVariant GID to charge for
# Example: gid://shopify/ProductVariant/1234567890
SHOPIFY_VARIANT_GID=gid://shopify/ProductVariant/0
